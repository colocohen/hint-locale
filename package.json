{
  "name": "hint-locale",
  "version": "2.2.0",
  "description": "Client & server locale detection from browser signals and HTTP headers - country, language, confidence scoring. Zero dependencies, single file.",
  "main": "hint-locale.js",
  "module": "hint-locale.mjs",
  "browser": "hint-locale.js",
  "exports": {
    ".": {
      "import": "./hint-locale.mjs",
      "require": "./hint-locale.js",
      "browser": "./hint-locale.js",
      "default": "./hint-locale.js"
    }
  },
  "types": "hint-locale.d.ts",
